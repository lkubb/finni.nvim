{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "requireLikeFunction": [
      "lazy_require"
    ]
  },
  "strict": {
    "arrayIndex": true,
    "docBaseConstMatchBaseType": true,
    "metaOverrideFileDefine": true,
    "requirePath": true,
    "typeCall": false
  },
  "diagnostics": {
    "disable": []
  },
  "workspace": {
    "ignoreGlobs": [
      "**/*_spec.lua",
      "**/busted.lua",
      "**/lazy/minit.lua"
    ],
    "library": [
      "$VIMRUNTIME",
      "./deps/fzf-lua/lua",
      "./deps/gitsigns.nvim/lua",
      "./deps/luv/library",
      "./deps/mini.nvim/lua",
      "./deps/neogit/lua",
      "./deps/oil.nvim/lua",
      "./deps/plenary.nvim/lua",
      "./deps/snacks.nvim/lua",
      "./deps/telescope.nvim/lua"
    ]
  }
}
